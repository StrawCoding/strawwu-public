# Cloudflare R2 credentials for direct ISO upload (NOT the Hermes build machine).
# Copy to iso-cdn.env and fill after running setup-iso-cdn-r2.sh
export STRAWWU_ISO_S3_ENDPOINT='https://<account-id>.r2.cloudflarestorage.com'
export STRAWWU_ISO_S3_BUCKET='strawwu-releases'
export STRAWWU_ISO_S3_PREFIX='releases'
export STRAWWU_ISO_CDN_BASE='https://download.strawwu.org'
export STRAWWU_ISO_S3_ACCESS_KEY=''
export STRAWWU_ISO_S3_SECRET_KEY=''
