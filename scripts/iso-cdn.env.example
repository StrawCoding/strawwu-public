# Cloudflare R2 credentials for whole-file ISO upload (NOT the Hermes build machine).
# 1) CF management token: store ONLY the latest in ~/.hermes/.env as
#    STRAWWU_CF_API_TOKEN / CLOUDFLARE_API_TOKEN (same value). Do not commit.
# 2) R2 S3 keys: Dashboard → R2 → Manage API Tokens → Create (Object Read & Write)
#    on bucket strawwu-releases. Access Key ID is 32 chars; Secret is shown once.
# 3) Copy this file to iso-cdn.env and fill S3 keys, then:
#      source scripts/iso-cdn.env
#      ./scripts/publish-github-release.sh 0.7.0.13
#      ./scripts/generate-manifest.sh
export STRAWWU_CF_ACCOUNT_ID='63342adb3f002cd3854e1fe49dd88323'
export STRAWWU_ISO_S3_ENDPOINT='https://63342adb3f002cd3854e1fe49dd88323.r2.cloudflarestorage.com'
export STRAWWU_ISO_S3_BUCKET='strawwu-releases'
export STRAWWU_ISO_S3_PREFIX='releases'
# Public r2.dev subdomain (custom domain download.strawwu.org needs zone on same CF account)
export STRAWWU_ISO_CDN_BASE='https://pub-5f85d511d7344db2be8308026a082b13.r2.dev'
export STRAWWU_ISO_S3_ACCESS_KEY=''
export STRAWWU_ISO_S3_SECRET_KEY=''
