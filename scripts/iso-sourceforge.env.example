# SourceForge credentials for whole-file ISO upload (no split parts).
# Copy to iso-sourceforge.env (gitignored) and fill in.
#
# Upload uses rsync over SSH to frs.sourceforge.net.
# Public download URL:
#   https://sourceforge.net/projects/<PROJECT>/files/releases/v<VERSION>/<ISO>/download

export STRAWWU_SF_USER=''            # SourceForge username
export STRAWWU_SF_PROJECT=''         # Project UNIX name (https://sourceforge.net/projects/<NAME>/)
export STRAWWU_SF_HOST='frs.sourceforge.net'
export STRAWWU_SF_REMOTE_ROOT='/home/frs/project'
export STRAWWU_SF_PREFIX='releases'  # remote path under project → releases/vX.Y.Z.W/

# Auth: prefer SSH key added to your SF account. Optional password (sshpass):
# export STRAWWU_SF_PASS=''

# Optional: Releases API key → set default Linux download after upload
# Account → Generate Releases API Key
# export STRAWWU_SF_API_KEY=''

# Public CDN base used in manifests / release notes
export STRAWWU_SF_CDN_BASE='https://sourceforge.net/projects'
